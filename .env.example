# =================================================================
# Yovo Social Autopilot — environment variables
# =================================================================
# Copy this file to `.env` for local testing. NEVER commit `.env`.
# In the cloud routine, put these in the routine's Secrets UI instead.
# -----------------------------------------------------------------

# --- App selector ---
APP=yovo
TIMEZONE=Europe/Zurich

# --- Dry-run gate ---
# true  → renders PNGs locally, does NOT publish to Instagram. Safe.
# false → actually publishes. Only flip after several successful dry runs.
DRY_RUN=true

# --- Anthropic API (LOCAL mode only) ---
# Used by src/lib/copy-generator.js when running `npm run dry-run` on your Mac.
# The cloud routine does NOT use this — Claude generates copy directly inside the routine.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# --- Instagram / Meta Graph API ---
# Required only when DRY_RUN=false.
# Get these from your Meta Developer dashboard once @yovo_app is converted to
# a Business account and linked to a Facebook Page.
META_LONG_LIVED_TOKEN=
IG_BUSINESS_ACCOUNT_ID=
FB_PAGE_ID=
META_GRAPH_VERSION=v22.0

# --- Image hosting (publish only) ---
# Comma-separated list of 2 PUBLIC URLs (the rendered PNGs). Meta pulls from
# these — they must be reachable without auth. Use a gh-pages branch or a
# signed-URL bucket. Leave empty in dry-run mode.
PUBLIC_IMAGE_URLS=

# --- Routine-injected copy (optional) ---
# When the cloud routine runs, it sets these per-execution after Claude has
# generated the copy. Leave empty for local dev — the API fallback kicks in.
ANGLE_ID=
THEME=
COPY_HOOK=
COPY_RESOLUTION=
COPY_CAPTION=
COPY_HASHTAGS=
